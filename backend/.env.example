# Local MySQL (Docker): mysql://zettaword:zettaword@localhost:3306/zettaword
#
# DigitalOcean Managed MySQL: use sslaccept=accept_invalid_certs for dev on Windows
# if the CA chain fails, or download DO’s CA and use sslcert=./certs/ca.pem with sslaccept=strict
# DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE?sslaccept=accept_invalid_certs"
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
FRONTEND_URL="http://localhost:5173"
PORT=4000
NODE_ENV=development

# AI providers (set the keys for the providers you use on each website)
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
