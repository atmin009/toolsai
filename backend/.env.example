# Local MySQL (Docker): mysql://zettaword:zettaword@localhost:3306/zettaword
#
# DigitalOcean Managed MySQL: use sslaccept=accept_invalid_certs for dev on Windows
# if the CA chain fails, or download DO’s CA and use sslcert=./certs/ca.pem with sslaccept=strict
# DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE?sslaccept=accept_invalid_certs"
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
FRONTEND_URL="http://localhost:5173"
PORT=4000
NODE_ENV=development

# Absolute base URL for links stored in DB (e.g. cover images). Defaults to http://localhost:{PORT}.
# PUBLIC_BASE_URL="https://api.example.com"

# Optional: header x-cron-secret for POST /api/articles/covers/batch and POST /api/articles/:id/cover
# CRON_SECRET=

# Text on auto-generated cover images (top-right)
# COVER_BRAND_NAME=FOCUS
# COVER_BRAND_TAGLINE=PROTECT WHAT MATTERS

# Cover image source: gemini | openai | none. Default gemini (Nano Banana 2 / Gemini 3.1 Flash Image).
# Uses Google API key from account Settings (คีย์ API ทั่วทั้งบัญชี) or GOOGLE_AI_API_KEY below.
# COVER_IMAGE_SOURCE=gemini

# Top-right logo on generated covers (PNG). Default: ../frontend/public/logo-focus.png from backend cwd.
# COVER_LOGO_PATH=C:/path/to/logo-focus.png

# AI providers (set the keys for the providers you use on each website)
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=
